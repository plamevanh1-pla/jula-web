<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion Partenaires Jula</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background-color: #f4f4f6; padding: 20px; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .form-card { background: #fff; padding: 25px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); max-width: 400px; width: 100%; text-align: center; }
        h2 { color: #f57c00; margin-bottom: 20px; }
        label { font-weight: bold; font-size: 13px; color: #495057; display: block; margin-top: 12px; text-align: left; }
        input { width: 100%; padding: 10px; margin-top: 5px; border-radius: 4px; border: 1px solid #ced4da; box-sizing: border-box; }
        .btn-submit { background-color: #f57c00; color: white; border: none; padding: 12px; width: 100%; border-radius: 4px; font-weight: bold; margin-top: 25px; cursor: pointer; font-size: 15px; }
    </style>
</head>
<body>
    <div class="form-card">
        <h2>🔐 Connexion Espace Jula</h2>
        <form action="/login-partner" method="POST">
            <label>Votre Adresse E-mail :</label>
            <input type="email" name="email" required placeholder="Ex: boutique@gmail.com">

            <label>Votre Mot de passe :</label>
            <input type="password" name="password" required placeholder="Saisissez votre mot de passe">

            <button type="submit" class="btn-submit">Se connecter à mon Espace</button>
        </form>
    </div>
</body>
</html>
