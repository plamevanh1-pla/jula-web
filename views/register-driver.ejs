 <!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jula - Inscription Livreur Coursier</title>
    <style>
        :root { --jula-orange: #f57c00; --jula-blue: #1072ba; --dark: #111417; }
        body { font-family: system-ui, sans-serif; background-color: #f8f9fa; margin: 0; padding: 20px; color: #333; }
        .form-container { max-width: 480px; background: white; margin: 30px auto; padding: 30px; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); border-top: 5px solid var(--jula-blue); }
        h2 { text-align: center; color: var(--dark); margin-bottom: 25px; font-weight: 800; }
        .form-group { margin-bottom: 20px; }
        label { display: block; font-weight: 600; margin-bottom: 8px; font-size: 14px; }
        input, select { width: 100%; padding: 12px; border: 2px solid #dee2e6; border-radius: 8px; box-sizing: border-box; font-size: 15px; }
        input:focus, select:focus { border-color: var(--jula-blue); outline: none; }
        input[type="file"] { padding: 8px; background: #f1f3f5; border: 2px dashed #ced4da; cursor: pointer; }
        .btn-submit { width: 100%; background: linear-gradient(135deg, var(--jula-blue), #0d5c97); color: white; padding: 14px; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; box-shadow: 0 4px 12px rgba(16,114,186,0.2); transition: 0.2s; }
        .btn-submit:hover { transform: translateY(-1px); box-shadow: 0 6px 15px rgba(16,114,186,0.3); }
        .info-file { font-size: 11px; color: #6c757d; margin-top: 4px; }
    </style>
</head>
<body>

    <div class="form-container">
        <h2>🛵 Devenir Livreur Jula</h2>
        
        <!-- Moteur d'envoi d'images actif -->
        <form action="/submit-partner" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="business_type" value="livreur">
            
            <div class="form-group">
                <label>Nom complet du coursier</label>
                <input type="text" name="full_name" placeholder="Ex: Sékou Touré" required>
            </div>

            <div class="form-group">
                <label>Numéro de Plaque d'Immatriculation</label>
                <input type="text" name="vehicle_plate" placeholder="Ex: 4567-IU-01" required>
            </div>

            <div class="form-group">
                <label>Numéro de Téléphone (Orange, Wave, MTN...)</label>
                <input type="tel" name="phone" placeholder="Ex: +225 0505..." required>
            </div>

            <div class="form-group">
                <label>Adresse Électronique (Email)</label>
                <input type="email" name="email" placeholder="Ex: sekou@jula-livraison.com" required>
            </div>

            <div class="form-group">
                <label>Mot de passe secret</label>
                <input type="password" name="password" placeholder="Minimum 6 caractères" required>
            </div>

            <div class="form-group">
                <label>Zone de livraison principale</label>
                <select name="country" required>
                    <option value="Côte d'Ivoire">🇨🇮 Côte d'Ivoire</option>
                    <option value="Sénégal">🇸🇳 Sénégal</option>
                    <option value="Togo">🇹🇬 Togo</option>
                    <option value="Bénin">🇧🇯 Bénin</option>
                </select>
            </div>

            <!-- 📸 CNI RECTO -->
            <div class="form-group">
                <label>📄 Pièce d'identité nationale (RECTO)</label>
                <input type="file" name="cni_recto" accept="image/*" required>
                <div class="info-file">Photo nette de l'avant de votre carte nationale d'identité.</div>
            </div>

            <!-- 📸 CNI VERSO -->
            <div class="form-group">
                <label>📄 Pièce d'identité nationale (VERSO)</label>
                <input type="file" name="cni_verso" accept="image/*" required>
                <div class="info-file">Photo nette de l'arrière de votre carte nationale d'identité.</div>
            </div>

            <!-- 📸 PHOTO DE LA MOTO / VÉHICULE -->
            <div class="form-group">
                <label>🏍️ Photo de votre Moto ou Véhicule</label>
                <input type="file" name="photo_vehicule" accept="image/*" required>
                <div class="info-file">Prenez une photo claire de votre engin où la plaque est visible.</div>
            </div>

            <button type="submit" class="btn-submit">Valider mon inscription de coursier</button>
        </form>
    </div>

</body>
</html>
